{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.py"
        },
        {
            "source": "/(.*)",
            "destination": "/Phase4_Frontend/frontend/dist/$1"
        }
    ],
    "functions": {
        "api/index.py": {
            "includeFiles": "data/**"
        }
    }
}