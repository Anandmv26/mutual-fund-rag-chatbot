{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.py"
        },
        {
            "source": "/(.*)",
            "destination": "/Phase4_Frontend/frontend/dist/$1"
        }
    ],
    "functions": {
        "api/index.py": {
            "runtime": "vercel-python@3.10",
            "memory": 1024,
            "maxDuration": 30
        }
    }
}